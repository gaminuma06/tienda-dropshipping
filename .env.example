# --- CONFIGURACIÓN DE SUPABASE (BASE DE DATOS) ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-clave-anon-key-de-supabase
SUPABASE_SERVICE_ROLE_KEY=tu-clave-service-role-para-escribir-pedidos (Backend)

# --- CONFIGURACIÓN DE META ADS (API DE CONVERSIONES - CAPI) ---
META_PIXEL_ID=tu-id-del-pixel-de-facebook
META_ACCESS_TOKEN=tu-token-de-acceso-de-api-de-conversiones-de-meta
META_TEST_EVENT_CODE=TEST12345 (Opcional: Solo para probar eventos en tiempo real en el administrador)

# --- CONFIGURACIÓN DE DROPI (INTEGRACIÓN API) ---
DROPI_API_URL=https://api.dropi.co
DROPI_EMAIL=tu-correo-de-dropi@correo.com
DROPI_PASSWORD=tu-contrasena-de-dropi
DROPI_INTEGRATION_KEY=tu-clave-de-integracion-aprobada-por-dropi (Opcional)

# --- SEGURIDAD DEL PANEL ADMINISTRATIVO ---
# Cambia este valor por la contraseña que quieras usar para ingresar a /admin
ADMIN_PASSWORD=contrasena_para_entrar_al_panel_admin

# --- CONFIGURACIÓN DE EFFI (INTEGRACIÓN API) ---
EFFI_API_URL=https://api.effisystems.com
EFFI_API_KEY=tu-api-key-de-effi
EFFI_TOKEN=tu-token-de-acceso-de-effi

# --- CONFIGURACIÓN DE HOKO (INTEGRACIÓN API) ---
HOKO_API_URL=https://api.hoko.com.co
HOKO_API_KEY=tu-api-key-de-hoko

